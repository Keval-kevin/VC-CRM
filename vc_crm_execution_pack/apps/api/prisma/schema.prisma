generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  INVITED
  ACTIVE
  DEACTIVATED
  LOCKED
}

enum RoleScope {
  GLOBAL
  TENANT
}

model Tenant {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  slug        String       @unique
  status      TenantStatus @default(ACTIVE)
  timezone    String       @default("Asia/Kolkata")
  locale      String       @default("en-IN")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  createdById String?      @db.Uuid
  updatedById String?      @db.Uuid
  deletedById String?      @db.Uuid

  users                   User[]
  roles                   Role[]
  auditLogs               AuditLog[]
  settings                TenantSettings?
  aiSettings              AIProviderSetting[]
  aiUsageLogs             AIUsageLog[]
  documentParsingJobs     DocumentParsingJob[]
  accounts                Account[]
  contacts                Contact[]
  leads                   Lead[]
  opportunities           Opportunity[]
  opportunityStageHistory OpportunityStageHistory[]
  proposals               Proposal[]
  proposalVersions        ProposalVersion[]
  proposalApprovals       ProposalApproval[]
  crmActivities           CrmActivity[]
  vendors                 Vendor[]
  candidates              Candidate[]
  requirements            StaffAugRequirement[]
  candidateSubmissions    CandidateSubmission[]
  interviews              Interview[]
  placements              Placement[]
  activities              ActivityTimelineItem[]

  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
}

enum AccountStatus {
  PROSPECT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ContactStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  NURTURING
  CONVERTED
  DISQUALIFIED
  LOST
}

enum OpportunityStage {
  QUALIFICATION
  DISCOVERY
  REQUIREMENT
  PROPOSAL
  NEGOTIATION
  VERBAL_COMMIT
  CONTRACTING
  WON
  LOST
}

enum ProposalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  SENT
  WON
  LOST
}

enum ProposalApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  TASK
  NOTE
}

enum ActivityStatus {
  OPEN
  COMPLETED
  CANCELLED
}

enum VendorDocumentStatus {
  NOT_STARTED
  REQUESTED
  IN_REVIEW
  SIGNED
  EXPIRED
}

enum VendorTier {
  STRATEGIC
  PREFERRED
  STANDARD
  WATCHLIST
}

enum VendorStatus {
  ACTIVE
  INACTIVE
  ONBOARDING
  ARCHIVED
}

enum VendorRiskStatus {
  CLEAR
  WARNING
  BLACKLISTED
}

enum CandidateStatus {
  ACTIVE
  INACTIVE
  PLACED
  ARCHIVED
}

enum CandidateAvailability {
  IMMEDIATE
  NOTICE_PERIOD
  NOT_AVAILABLE
  UNKNOWN
}

enum RequirementPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum RequirementStatus {
  DRAFT
  OPEN
  ON_HOLD
  FILLED
  CANCELLED
  CLOSED
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
}

enum SubmissionStatus {
  SUBMITTED
  TECHNICAL_REVIEW
  CLIENT_SUBMITTED
  INTERVIEW_SCHEDULED
  SELECTED
  REJECTED
  WITHDRAWN
}

enum InterviewOutcome {
  PENDING
  PASSED
  FAILED
  NO_SHOW
  RESCHEDULED
}

enum PlacementBillingStatus {
  NOT_STARTED
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum AIProvider {
  OPENAI
  ANTHROPIC
  GEMINI
}

enum AIJobType {
  RESUME_PARSE
  PROPOSAL_SOW_PARSE
  VENDOR_WEBSITE_INTELLIGENCE
}

enum AIJobStatus {
  PENDING
  REVIEW_READY
  APPROVED
  REJECTED
  SAVED
  FAILED
  RETRY_WAITING
}

enum AIUsageStatus {
  SUCCESS
  FAILED
  SKIPPED
}

model Lead {
  id                   String     @id @default(uuid()) @db.Uuid
  tenantId             String     @db.Uuid
  firstName            String
  lastName             String
  email                String?
  phone                String?
  company              String?
  website              String?
  companyDomain        String?
  linkedinUrl          String?
  country              String?
  source               String
  serviceInterest      String?
  budgetRange          String?
  status               LeadStatus @default(NEW)
  score                Int        @default(0)
  scoreReason          String?
  ownerId              String?    @db.Uuid
  followUpAt           DateTime?
  lostReason           String?
  disqualifiedReason   String?
  importBatchId        String?
  importExternalId     String?
  importSourceFilename String?
  notes                String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  deletedAt            DateTime?
  createdById          String?    @db.Uuid
  updatedById          String?    @db.Uuid
  deletedById          String?    @db.Uuid

  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  activities    ActivityTimelineItem[]
  opportunities Opportunity[]
  crmActivities CrmActivity[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, ownerId])
  @@index([tenantId, source])
  @@index([tenantId, followUpAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([tenantId, email])
  @@index([tenantId, phone])
  @@index([tenantId, companyDomain])
  @@index([deletedAt])
}

model Opportunity {
  id                    String           @id @default(uuid()) @db.Uuid
  tenantId              String           @db.Uuid
  accountId             String?          @db.Uuid
  primaryContactId      String?          @db.Uuid
  leadId                String?          @db.Uuid
  name                  String
  stage                 OpportunityStage @default(QUALIFICATION)
  probability           Int              @default(10)
  valueCents            Int              @default(0)
  currency              String           @default("INR")
  expectedCloseDate     DateTime?
  weightedForecastCents Int              @default(0)
  ownerId               String?          @db.Uuid
  stageChangedAt        DateTime         @default(now())
  wonAt                 DateTime?
  lostAt                DateTime?
  lostReason            String?
  notes                 String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  deletedAt             DateTime?
  createdById           String?          @db.Uuid
  updatedById           String?          @db.Uuid
  deletedById           String?          @db.Uuid

  tenant         Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  account        Account?                  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  primaryContact Contact?                  @relation(fields: [primaryContactId], references: [id], onDelete: SetNull)
  lead           Lead?                     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  activities     ActivityTimelineItem[]
  stageHistory   OpportunityStageHistory[]
  proposals      Proposal[]
  crmActivities  CrmActivity[]
  requirements   StaffAugRequirement[]

  @@index([tenantId])
  @@index([tenantId, accountId])
  @@index([tenantId, primaryContactId])
  @@index([tenantId, leadId])
  @@index([tenantId, ownerId])
  @@index([tenantId, stage])
  @@index([tenantId, expectedCloseDate])
  @@index([tenantId, stageChangedAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([deletedAt])
}

model OpportunityStageHistory {
  id            String            @id @default(uuid()) @db.Uuid
  tenantId      String            @db.Uuid
  opportunityId String            @db.Uuid
  fromStage     OpportunityStage?
  toStage       OpportunityStage
  changedAt     DateTime          @default(now())
  changedById   String?           @db.Uuid
  note          String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, opportunityId])
  @@index([tenantId, toStage])
  @@index([tenantId, changedAt])
  @@index([deletedAt])
}

model Proposal {
  id                   String         @id @default(uuid()) @db.Uuid
  tenantId             String         @db.Uuid
  opportunityId        String?        @db.Uuid
  accountId            String?        @db.Uuid
  contactId            String?        @db.Uuid
  title                String
  templateKey          String
  status               ProposalStatus @default(DRAFT)
  currentVersionNumber Int            @default(1)
  approvalRole         String?
  ownerId              String?        @db.Uuid
  valueCents           Int            @default(0)
  currency             String         @default("INR")
  submittedAt          DateTime?
  approvedAt           DateTime?
  rejectedAt           DateTime?
  sentAt               DateTime?
  wonAt                DateTime?
  lostAt               DateTime?
  pdfExportRequestedAt DateTime?
  notes                String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  deletedAt            DateTime?
  createdById          String?        @db.Uuid
  updatedById          String?        @db.Uuid
  deletedById          String?        @db.Uuid

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  opportunity Opportunity?       @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  account     Account?           @relation(fields: [accountId], references: [id], onDelete: SetNull)
  contact     Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  versions    ProposalVersion[]
  approvals   ProposalApproval[]
  activities  CrmActivity[]

  @@index([tenantId])
  @@index([tenantId, opportunityId])
  @@index([tenantId, accountId])
  @@index([tenantId, contactId])
  @@index([tenantId, status])
  @@index([tenantId, ownerId])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([deletedAt])
}

model ProposalVersion {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  proposalId    String    @db.Uuid
  versionNumber Int
  templateKey   String
  title         String
  contentJson   Json
  changeNote    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  createdById   String?   @db.Uuid
  updatedById   String?   @db.Uuid
  deletedById   String?   @db.Uuid

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@unique([proposalId, versionNumber])
  @@index([tenantId])
  @@index([tenantId, proposalId])
  @@index([tenantId, createdAt])
  @@index([deletedAt])
}

model ProposalApproval {
  id             String                 @id @default(uuid()) @db.Uuid
  tenantId       String                 @db.Uuid
  proposalId     String                 @db.Uuid
  roleKey        String
  status         ProposalApprovalStatus @default(PENDING)
  approverUserId String?                @db.Uuid
  decidedAt      DateTime?
  comment        String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  deletedAt      DateTime?
  createdById    String?                @db.Uuid
  updatedById    String?                @db.Uuid
  deletedById    String?                @db.Uuid

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, proposalId])
  @@index([tenantId, roleKey])
  @@index([tenantId, status])
  @@index([deletedAt])
}

model CrmActivity {
  id            String         @id @default(uuid()) @db.Uuid
  tenantId      String         @db.Uuid
  type          ActivityType
  status        ActivityStatus @default(OPEN)
  title         String
  description   String?
  ownerId       String?        @db.Uuid
  leadId        String?        @db.Uuid
  accountId     String?        @db.Uuid
  contactId     String?        @db.Uuid
  opportunityId String?        @db.Uuid
  proposalId    String?        @db.Uuid
  vendorId      String?        @db.Uuid
  candidateId   String?        @db.Uuid
  candidateRef  String?
  vendorRef     String?
  dueAt         DateTime?
  reminderAt    DateTime?
  completedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  createdById   String?        @db.Uuid
  updatedById   String?        @db.Uuid
  deletedById   String?        @db.Uuid

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  account     Account?     @relation(fields: [accountId], references: [id], onDelete: SetNull)
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  proposal    Proposal?    @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  vendor      Vendor?      @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  candidate   Candidate?   @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, status])
  @@index([tenantId, ownerId])
  @@index([tenantId, dueAt])
  @@index([tenantId, reminderAt])
  @@index([tenantId, leadId])
  @@index([tenantId, accountId])
  @@index([tenantId, contactId])
  @@index([tenantId, opportunityId])
  @@index([tenantId, proposalId])
  @@index([tenantId, vendorId])
  @@index([tenantId, candidateId])
  @@index([deletedAt])
}

model Vendor {
  id                  String               @id @default(uuid()) @db.Uuid
  tenantId            String               @db.Uuid
  name                String
  website             String?
  domain              String?
  email               String?
  phone               String?
  categories          String[]             @default([])
  expertiseSkills     String[]             @default([])
  decisionMakerName   String?
  decisionMakerTitle  String?
  decisionMakerEmail  String?
  decisionMakerPhone  String?
  city                String?
  state               String?
  country             String?
  timezone            String?
  companyOwnershipTag String
  ndaStatus           VendorDocumentStatus @default(NOT_STARTED)
  msaStatus           VendorDocumentStatus @default(NOT_STARTED)
  rateCard            Json?
  tier                VendorTier           @default(STANDARD)
  status              VendorStatus         @default(ONBOARDING)
  riskStatus          VendorRiskStatus     @default(CLEAR)
  riskReason          String?
  deliveryScore       Int                  @default(0)
  qualityScore        Int                  @default(0)
  responsivenessScore Int                  @default(0)
  complianceScore     Int                  @default(0)
  overallScore        Int                  @default(0)
  portalEnabled       Boolean              @default(false)
  portalSlug          String?
  portalInviteEmail   String?
  portalLastLoginAt   DateTime?
  notes               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  createdById         String?              @db.Uuid
  updatedById         String?              @db.Uuid
  deletedById         String?              @db.Uuid

  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  crmActivities CrmActivity[]
  candidates    Candidate[]
  submissions   CandidateSubmission[]
  interviews    Interview[]
  placements    Placement[]

  @@unique([tenantId, portalSlug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, tier])
  @@index([tenantId, riskStatus])
  @@index([tenantId, companyOwnershipTag])
  @@index([tenantId, domain])
  @@index([tenantId, country])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([deletedAt])
}

model Candidate {
  id                String                @id @default(uuid()) @db.Uuid
  tenantId          String                @db.Uuid
  vendorId          String?               @db.Uuid
  firstName         String
  lastName          String
  email             String?
  phone             String?
  resumeFileName    String?
  resumeStorageKey  String?
  resumeMimeType    String?
  resumeSizeBytes   Int?
  resumeUploadedAt  DateTime?
  primarySkills     String[]              @default([])
  secondarySkills   String[]              @default([])
  experienceYears   Float?
  currentCtcCents   Int?
  expectedCtcCents  Int?
  currency          String                @default("INR")
  noticePeriodDays  Int?
  city              String?
  state             String?
  country           String?
  timezone          String?
  availability      CandidateAvailability @default(UNKNOWN)
  availableFrom     DateTime?
  consentStatus     Boolean               @default(false)
  consentCapturedAt DateTime?
  consentSource     String?
  blacklisted       Boolean               @default(false)
  blacklistReason   String?
  status            CandidateStatus       @default(ACTIVE)
  resumeParsed      Boolean               @default(false)
  resumeParseStatus String                @default("PENDING")
  parsedResumeJson  Json?
  notes             String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  deletedAt         DateTime?
  createdById       String?               @db.Uuid
  updatedById       String?               @db.Uuid
  deletedById       String?               @db.Uuid

  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  vendor        Vendor?               @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  crmActivities CrmActivity[]
  submissions   CandidateSubmission[]
  placements    Placement[]
  interviews    Interview[]

  @@index([tenantId])
  @@index([tenantId, vendorId])
  @@index([tenantId, status])
  @@index([tenantId, availability])
  @@index([tenantId, email])
  @@index([tenantId, phone])
  @@index([tenantId, country])
  @@index([tenantId, city])
  @@index([tenantId, blacklisted])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([deletedAt])
}

model StaffAugRequirement {
  id                 String              @id @default(uuid()) @db.Uuid
  tenantId           String              @db.Uuid
  accountId          String?             @db.Uuid
  opportunityId      String?             @db.Uuid
  roleTitle          String
  skills             String[]            @default([])
  minExperienceYears Float?
  maxExperienceYears Float?
  budgetMinCents     Int?
  budgetMaxCents     Int?
  currency           String              @default("INR")
  location           String?
  workMode           WorkMode            @default(REMOTE)
  positions          Int                 @default(1)
  priority           RequirementPriority @default(MEDIUM)
  status             RequirementStatus   @default(OPEN)
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  createdById        String?             @db.Uuid
  updatedById        String?             @db.Uuid
  deletedById        String?             @db.Uuid

  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  account     Account?              @relation(fields: [accountId], references: [id], onDelete: SetNull)
  opportunity Opportunity?          @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  submissions CandidateSubmission[]
  interviews  Interview[]
  placements  Placement[]

  @@index([tenantId])
  @@index([tenantId, accountId])
  @@index([tenantId, opportunityId])
  @@index([tenantId, status])
  @@index([tenantId, priority])
  @@index([tenantId, workMode])
  @@index([tenantId, location])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([deletedAt])
}

model CandidateSubmission {
  id                   String           @id @default(uuid()) @db.Uuid
  tenantId             String           @db.Uuid
  requirementId        String           @db.Uuid
  candidateId          String           @db.Uuid
  vendorId             String?          @db.Uuid
  status               SubmissionStatus @default(SUBMITTED)
  technicalReviewNotes String?
  technicalReviewedAt  DateTime?
  clientSubmittedAt    DateTime?
  interviewScheduledAt DateTime?
  interviewPlaceholder String?
  feedback             String?
  feedbackRating       Int?
  submittedAt          DateTime         @default(now())
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  deletedAt            DateTime?
  createdById          String?          @db.Uuid
  updatedById          String?          @db.Uuid
  deletedById          String?          @db.Uuid

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  requirement StaffAugRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  candidate   Candidate           @relation(fields: [candidateId], references: [id], onDelete: Restrict)
  vendor      Vendor?             @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  interviews  Interview[]
  placement   Placement?

  @@index([tenantId])
  @@index([tenantId, requirementId])
  @@index([tenantId, candidateId])
  @@index([tenantId, vendorId])
  @@index([tenantId, status])
  @@index([tenantId, submittedAt])
  @@index([tenantId, createdAt])
  @@index([deletedAt])
}

model Interview {
  id            String           @id @default(uuid()) @db.Uuid
  tenantId      String           @db.Uuid
  submissionId  String           @db.Uuid
  candidateId   String           @db.Uuid
  requirementId String           @db.Uuid
  roundNumber   Int
  interviewer   String
  scheduledAt   DateTime
  feedback      String?
  outcome       InterviewOutcome @default(PENDING)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?
  createdById   String?          @db.Uuid
  updatedById   String?          @db.Uuid
  deletedById   String?          @db.Uuid

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  submission  CandidateSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  candidate   Candidate           @relation(fields: [candidateId], references: [id], onDelete: Restrict)
  requirement StaffAugRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  vendor      Vendor?             @relation(fields: [vendorId], references: [id])
  vendorId    String?             @db.Uuid

  @@index([tenantId])
  @@index([tenantId, submissionId])
  @@index([tenantId, candidateId])
  @@index([tenantId, requirementId])
  @@index([tenantId, scheduledAt])
  @@index([tenantId, outcome])
  @@index([deletedAt])
}

model Placement {
  id                     String                 @id @default(uuid()) @db.Uuid
  tenantId               String                 @db.Uuid
  submissionId           String                 @unique @db.Uuid
  candidateId            String                 @db.Uuid
  requirementId          String                 @db.Uuid
  vendorId               String?                @db.Uuid
  clientBillingRateCents Int
  vendorCostCents        Int
  marginCents            Int
  marginPercentBasis     Int
  currency               String                 @default("INR")
  joiningDate            DateTime
  replacementPeriodDays  Int                    @default(0)
  billingStatus          PlacementBillingStatus @default(NOT_STARTED)
  notes                  String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  deletedAt              DateTime?
  createdById            String?                @db.Uuid
  updatedById            String?                @db.Uuid
  deletedById            String?                @db.Uuid

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  submission  CandidateSubmission @relation(fields: [submissionId], references: [id], onDelete: Restrict)
  candidate   Candidate           @relation(fields: [candidateId], references: [id], onDelete: Restrict)
  requirement StaffAugRequirement @relation(fields: [requirementId], references: [id], onDelete: Restrict)
  vendor      Vendor?             @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, candidateId])
  @@index([tenantId, requirementId])
  @@index([tenantId, vendorId])
  @@index([tenantId, billingStatus])
  @@index([tenantId, joiningDate])
  @@index([deletedAt])
}

model Account {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @db.Uuid
  name        String
  website     String?
  domain      String?
  industry    String?
  phone       String?
  city        String?
  country     String?
  status      AccountStatus @default(PROSPECT)
  ownerId     String?       @db.Uuid
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  createdById String?       @db.Uuid
  updatedById String?       @db.Uuid
  deletedById String?       @db.Uuid

  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  contacts      Contact[]
  opportunities Opportunity[]
  activities    ActivityTimelineItem[]
  proposals     Proposal[]
  crmActivities CrmActivity[]
  requirements  StaffAugRequirement[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, ownerId])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([tenantId, name])
  @@index([tenantId, domain])
  @@index([deletedAt])
}

model Contact {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @db.Uuid
  accountId      String?       @db.Uuid
  firstName      String
  lastName       String
  email          String?
  phone          String?
  title          String?
  linkedinUrl    String?
  decisionMaker  Boolean       @default(false)
  influenceLevel String?
  status         ContactStatus @default(ACTIVE)
  ownerId        String?       @db.Uuid
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  createdById    String?       @db.Uuid
  updatedById    String?       @db.Uuid
  deletedById    String?       @db.Uuid

  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  account       Account?               @relation(fields: [accountId], references: [id], onDelete: SetNull)
  opportunities Opportunity[]
  activities    ActivityTimelineItem[]
  proposals     Proposal[]
  crmActivities CrmActivity[]

  @@index([tenantId])
  @@index([tenantId, accountId])
  @@index([tenantId, status])
  @@index([tenantId, ownerId])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([tenantId, email])
  @@index([tenantId, phone])
  @@index([deletedAt])
}

model ActivityTimelineItem {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  leadId        String?   @db.Uuid
  accountId     String?   @db.Uuid
  contactId     String?   @db.Uuid
  opportunityId String?   @db.Uuid
  type          String
  title         String
  description   String?
  occurredAt    DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  createdById   String?   @db.Uuid
  updatedById   String?   @db.Uuid
  deletedById   String?   @db.Uuid

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  account     Account?     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, leadId])
  @@index([tenantId, accountId])
  @@index([tenantId, contactId])
  @@index([tenantId, opportunityId])
  @@index([tenantId, occurredAt])
  @@index([deletedAt])
}

model TenantSettings {
  id                    String    @id @default(uuid()) @db.Uuid
  tenantId              String    @unique @db.Uuid
  companyName           String
  timezone              String    @default("Asia/Kolkata")
  locale                String    @default("en-IN")
  sessionTimeoutMinutes Int       @default(480)
  passwordMinLength     Int       @default(8)
  requireStrongPassword Boolean   @default(true)
  ipAllowlist           String[]  @default([])
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?
  createdById           String?   @db.Uuid
  updatedById           String?   @db.Uuid
  deletedById           String?   @db.Uuid

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([deletedAt])
}

model AIProviderSetting {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @db.Uuid
  provider           String
  defaultModel       String
  enabled            Boolean   @default(false)
  monthlyBudgetCents Int       @default(0)
  encryptedApiKey    String?
  apiKeyIv           String?
  apiKeyTag          String?
  keyLastFour        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?
  createdById        String?   @db.Uuid
  updatedById        String?   @db.Uuid
  deletedById        String?   @db.Uuid

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@index([provider])
  @@index([deletedAt])
}

model AIUsageLog {
  id                 String        @id @default(uuid()) @db.Uuid
  tenantId           String        @db.Uuid
  parsingJobId       String?       @db.Uuid
  provider           AIProvider
  model              String
  feature            String
  promptTokens       Int           @default(0)
  completionTokens   Int           @default(0)
  totalTokens        Int           @default(0)
  estimatedCostCents Int           @default(0)
  status             AIUsageStatus @default(SKIPPED)
  failureReason      String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?

  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parsingJob DocumentParsingJob? @relation(fields: [parsingJobId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, provider])
  @@index([tenantId, feature])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([parsingJobId])
  @@index([deletedAt])
}

model DocumentParsingJob {
  id                 String      @id @default(uuid()) @db.Uuid
  tenantId           String      @db.Uuid
  provider           AIProvider
  jobType            AIJobType
  status             AIJobStatus @default(PENDING)
  sourceEntityType   String
  sourceEntityId     String      @db.Uuid
  sourceDocumentName String?
  sourceDocumentUrl  String?
  model              String
  parsedDataJson     Json?
  approvedDataJson   Json?
  rejectionReason    String?
  failureReason      String?
  attempts           Int         @default(0)
  maxAttempts        Int         @default(3)
  retryAt            DateTime?
  promptTokens       Int         @default(0)
  completionTokens   Int         @default(0)
  totalTokens        Int         @default(0)
  estimatedCostCents Int         @default(0)
  approvedAt         DateTime?
  approvedById       String?     @db.Uuid
  savedAt            DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  deletedAt          DateTime?
  createdById        String?     @db.Uuid
  updatedById        String?     @db.Uuid
  deletedById        String?     @db.Uuid

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usageLogs AIUsageLog[]

  @@index([tenantId])
  @@index([tenantId, provider])
  @@index([tenantId, jobType])
  @@index([tenantId, status])
  @@index([tenantId, sourceEntityType, sourceEntityId])
  @@index([tenantId, createdAt])
  @@index([deletedAt])
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String?    @db.Uuid
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  status       UserStatus @default(ACTIVE)
  isSuperAdmin Boolean    @default(false)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  createdById  String?    @db.Uuid
  updatedById  String?    @db.Uuid
  deletedById  String?    @db.Uuid

  tenant       Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  userRoles    UserRole[]
  sessions     UserSession[]
  resetTokens  PasswordResetToken[]
  auditActions AuditLog[]           @relation("AuditActor")

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([email])
  @@index([deletedAt])
}

model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  tenantId         String?   @db.Uuid
  refreshTokenHash String    @unique
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  createdById      String?   @db.Uuid
  updatedById      String?   @db.Uuid
  deletedById      String?   @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([deletedAt])
}

model PasswordResetToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedById String?   @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
  @@index([deletedAt])
}

model Role {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String?   @db.Uuid
  scope       RoleScope
  name        String
  key         String
  uniqueKey   String    @unique
  description String?
  isSystem    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedById String?   @db.Uuid

  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  users       UserRole[]
  permissions RolePermission[]

  @@index([tenantId])
  @@index([tenantId, key])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([deletedAt])
}

model Permission {
  id          String    @id @default(uuid()) @db.Uuid
  key         String    @unique
  name        String
  category    String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedById String?   @db.Uuid

  roles RolePermission[]

  @@index([category])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
}

model UserRole {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  roleId      String    @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedById String?   @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([deletedAt])
}

model RolePermission {
  id           String    @id @default(uuid()) @db.Uuid
  roleId       String    @db.Uuid
  permissionId String    @db.Uuid
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  createdById  String?   @db.Uuid
  updatedById  String?   @db.Uuid
  deletedById  String?   @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@index([deletedAt])
}

model AuditLog {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String?   @db.Uuid
  actorUserId String?   @db.Uuid
  action      String
  entityType  String
  entityId    String?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedById String?   @db.Uuid

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  actor  User?   @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, action])
  @@index([tenantId, entityType])
  @@index([tenantId, createdAt])
  @@index([actorUserId])
  @@index([deletedAt])
}
