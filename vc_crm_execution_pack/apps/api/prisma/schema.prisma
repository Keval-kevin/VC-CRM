generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  INVITED
  ACTIVE
  DEACTIVATED
  LOCKED
}

enum RoleScope {
  GLOBAL
  TENANT
}

model Tenant {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  slug        String       @unique
  status      TenantStatus @default(ACTIVE)
  timezone    String       @default("Asia/Kolkata")
  locale      String       @default("en-IN")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  createdById String?      @db.Uuid
  updatedById String?      @db.Uuid
  deletedById String?      @db.Uuid

  users                   User[]
  roles                   Role[]
  auditLogs               AuditLog[]
  settings                TenantSettings?
  aiSettings              AIProviderSetting[]
  accounts                Account[]
  contacts                Contact[]
  leads                   Lead[]
  opportunities           Opportunity[]
  opportunityStageHistory OpportunityStageHistory[]
  activities              ActivityTimelineItem[]

  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
}

enum AccountStatus {
  PROSPECT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ContactStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  NURTURING
  CONVERTED
  DISQUALIFIED
  LOST
}

enum OpportunityStage {
  QUALIFICATION
  DISCOVERY
  REQUIREMENT
  PROPOSAL
  NEGOTIATION
  VERBAL_COMMIT
  CONTRACTING
  WON
  LOST
}

model Lead {
  id                   String     @id @default(uuid()) @db.Uuid
  tenantId             String     @db.Uuid
  firstName            String
  lastName             String
  email                String?
  phone                String?
  company              String?
  website              String?
  companyDomain        String?
  linkedinUrl          String?
  country              String?
  source               String
  serviceInterest      String?
  budgetRange          String?
  status               LeadStatus @default(NEW)
  score                Int        @default(0)
  scoreReason          String?
  ownerId              String?    @db.Uuid
  followUpAt           DateTime?
  lostReason           String?
  disqualifiedReason   String?
  importBatchId        String?
  importExternalId     String?
  importSourceFilename String?
  notes                String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  deletedAt            DateTime?
  createdById          String?    @db.Uuid
  updatedById          String?    @db.Uuid
  deletedById          String?    @db.Uuid

  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  activities    ActivityTimelineItem[]
  opportunities Opportunity[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, ownerId])
  @@index([tenantId, source])
  @@index([tenantId, followUpAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([tenantId, email])
  @@index([tenantId, phone])
  @@index([tenantId, companyDomain])
  @@index([deletedAt])
}

model Opportunity {
  id                    String           @id @default(uuid()) @db.Uuid
  tenantId              String           @db.Uuid
  accountId             String?          @db.Uuid
  primaryContactId      String?          @db.Uuid
  leadId                String?          @db.Uuid
  name                  String
  stage                 OpportunityStage @default(QUALIFICATION)
  probability           Int              @default(10)
  valueCents            Int              @default(0)
  currency              String           @default("INR")
  expectedCloseDate     DateTime?
  weightedForecastCents Int              @default(0)
  ownerId               String?          @db.Uuid
  stageChangedAt        DateTime         @default(now())
  wonAt                 DateTime?
  lostAt                DateTime?
  lostReason            String?
  notes                 String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  deletedAt             DateTime?
  createdById           String?          @db.Uuid
  updatedById           String?          @db.Uuid
  deletedById           String?          @db.Uuid

  tenant         Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  account        Account?                  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  primaryContact Contact?                  @relation(fields: [primaryContactId], references: [id], onDelete: SetNull)
  lead           Lead?                     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  activities     ActivityTimelineItem[]
  stageHistory   OpportunityStageHistory[]

  @@index([tenantId])
  @@index([tenantId, accountId])
  @@index([tenantId, primaryContactId])
  @@index([tenantId, leadId])
  @@index([tenantId, ownerId])
  @@index([tenantId, stage])
  @@index([tenantId, expectedCloseDate])
  @@index([tenantId, stageChangedAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([deletedAt])
}

model OpportunityStageHistory {
  id            String            @id @default(uuid()) @db.Uuid
  tenantId      String            @db.Uuid
  opportunityId String            @db.Uuid
  fromStage     OpportunityStage?
  toStage       OpportunityStage
  changedAt     DateTime          @default(now())
  changedById   String?           @db.Uuid
  note          String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, opportunityId])
  @@index([tenantId, toStage])
  @@index([tenantId, changedAt])
  @@index([deletedAt])
}

model Account {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @db.Uuid
  name        String
  website     String?
  domain      String?
  industry    String?
  phone       String?
  city        String?
  country     String?
  status      AccountStatus @default(PROSPECT)
  ownerId     String?       @db.Uuid
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  createdById String?       @db.Uuid
  updatedById String?       @db.Uuid
  deletedById String?       @db.Uuid

  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  contacts      Contact[]
  opportunities Opportunity[]
  activities    ActivityTimelineItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, ownerId])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([tenantId, name])
  @@index([tenantId, domain])
  @@index([deletedAt])
}

model Contact {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @db.Uuid
  accountId      String?       @db.Uuid
  firstName      String
  lastName       String
  email          String?
  phone          String?
  title          String?
  linkedinUrl    String?
  decisionMaker  Boolean       @default(false)
  influenceLevel String?
  status         ContactStatus @default(ACTIVE)
  ownerId        String?       @db.Uuid
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  createdById    String?       @db.Uuid
  updatedById    String?       @db.Uuid
  deletedById    String?       @db.Uuid

  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  account       Account?               @relation(fields: [accountId], references: [id], onDelete: SetNull)
  opportunities Opportunity[]
  activities    ActivityTimelineItem[]

  @@index([tenantId])
  @@index([tenantId, accountId])
  @@index([tenantId, status])
  @@index([tenantId, ownerId])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([tenantId, email])
  @@index([tenantId, phone])
  @@index([deletedAt])
}

model ActivityTimelineItem {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  leadId        String?   @db.Uuid
  accountId     String?   @db.Uuid
  contactId     String?   @db.Uuid
  opportunityId String?   @db.Uuid
  type          String
  title         String
  description   String?
  occurredAt    DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  createdById   String?   @db.Uuid
  updatedById   String?   @db.Uuid
  deletedById   String?   @db.Uuid

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  account     Account?     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, leadId])
  @@index([tenantId, accountId])
  @@index([tenantId, contactId])
  @@index([tenantId, opportunityId])
  @@index([tenantId, occurredAt])
  @@index([deletedAt])
}

model TenantSettings {
  id                    String    @id @default(uuid()) @db.Uuid
  tenantId              String    @unique @db.Uuid
  companyName           String
  timezone              String    @default("Asia/Kolkata")
  locale                String    @default("en-IN")
  sessionTimeoutMinutes Int       @default(480)
  passwordMinLength     Int       @default(8)
  requireStrongPassword Boolean   @default(true)
  ipAllowlist           String[]  @default([])
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?
  createdById           String?   @db.Uuid
  updatedById           String?   @db.Uuid
  deletedById           String?   @db.Uuid

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([deletedAt])
}

model AIProviderSetting {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @db.Uuid
  provider           String
  defaultModel       String
  enabled            Boolean   @default(false)
  monthlyBudgetCents Int       @default(0)
  encryptedApiKey    String?
  apiKeyIv           String?
  apiKeyTag          String?
  keyLastFour        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?
  createdById        String?   @db.Uuid
  updatedById        String?   @db.Uuid
  deletedById        String?   @db.Uuid

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@index([provider])
  @@index([deletedAt])
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String?    @db.Uuid
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  status       UserStatus @default(ACTIVE)
  isSuperAdmin Boolean    @default(false)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  createdById  String?    @db.Uuid
  updatedById  String?    @db.Uuid
  deletedById  String?    @db.Uuid

  tenant       Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  userRoles    UserRole[]
  sessions     UserSession[]
  resetTokens  PasswordResetToken[]
  auditActions AuditLog[]           @relation("AuditActor")

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([email])
  @@index([deletedAt])
}

model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  tenantId         String?   @db.Uuid
  refreshTokenHash String    @unique
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  createdById      String?   @db.Uuid
  updatedById      String?   @db.Uuid
  deletedById      String?   @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([deletedAt])
}

model PasswordResetToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedById String?   @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
  @@index([deletedAt])
}

model Role {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String?   @db.Uuid
  scope       RoleScope
  name        String
  key         String
  uniqueKey   String    @unique
  description String?
  isSystem    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedById String?   @db.Uuid

  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  users       UserRole[]
  permissions RolePermission[]

  @@index([tenantId])
  @@index([tenantId, key])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([deletedAt])
}

model Permission {
  id          String    @id @default(uuid()) @db.Uuid
  key         String    @unique
  name        String
  category    String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedById String?   @db.Uuid

  roles RolePermission[]

  @@index([category])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
}

model UserRole {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  roleId      String    @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedById String?   @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([deletedAt])
}

model RolePermission {
  id           String    @id @default(uuid()) @db.Uuid
  roleId       String    @db.Uuid
  permissionId String    @db.Uuid
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  createdById  String?   @db.Uuid
  updatedById  String?   @db.Uuid
  deletedById  String?   @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@index([deletedAt])
}

model AuditLog {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String?   @db.Uuid
  actorUserId String?   @db.Uuid
  action      String
  entityType  String
  entityId    String?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedById String?   @db.Uuid

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  actor  User?   @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, action])
  @@index([tenantId, entityType])
  @@index([tenantId, createdAt])
  @@index([actorUserId])
  @@index([deletedAt])
}
