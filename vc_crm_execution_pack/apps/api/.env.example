NODE_ENV=development
API_PORT=4000

POSTGRES_DB=vc_crm
POSTGRES_USER=vc_crm
POSTGRES_PASSWORD=vc_crm_dev_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://vc_crm:vc_crm_dev_password@localhost:5432/vc_crm?schema=public

REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_ROOT_USER=vc_crm_minio
MINIO_ROOT_PASSWORD=vc_crm_minio_dev_password
MINIO_BUCKET=vc-crm-local

JWT_ACCESS_SECRET=replace-with-local-access-secret-32-chars-minimum
JWT_REFRESH_SECRET=replace-with-local-refresh-secret-32-chars-minimum
PASSWORD_RESET_SECRET=replace-with-local-reset-secret
AI_KEY_ENCRYPTION_SECRET=replace-with-local-ai-key-secret-32-chars
